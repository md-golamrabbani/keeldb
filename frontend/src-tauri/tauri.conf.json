{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Migration Studio",
  "version": "0.1.0",
  "identifier": "net.fiberathome.migrationstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Migration Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/migration-backend"]
  }
}
